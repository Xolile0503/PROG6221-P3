<Window x:Class="CyberSecurityBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberSecurity Bot" Height="650" Width="900"
        WindowStartupLocation="CenterScreen"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Pink/Purple Gradient Background -->
        <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#2A0A2A" Offset="0"/>
            <GradientStop Color="#4A1A4A" Offset="0.5"/>
            <GradientStop Color="#6A2A6A" Offset="1"/>
        </LinearGradientBrush>

        <!-- Button Style (Pink/Purple) -->
        <Style x:Key="PinkPurpleButton" TargetType="Button">
            <Setter Property="Background" Value="#9B4D96"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderBrush="#B56BB5" 
                                BorderThickness="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B56BB5"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#7A3A7A"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#666"/>
                    <Setter Property="Foreground" Value="#AAA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Red Exit Button Style -->
        <Style x:Key="RedExitButton" TargetType="Button" BasedOn="{StaticResource PinkPurpleButton}">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="BorderBrush" Value="#E74C3C"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E74C3C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#922B21"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A0A1A"/>
            <Setter Property="Foreground" Value="#E6C6E6"/>
            <Setter Property="BorderBrush" Value="#9B4D96"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="CaretBrush" Value="#E6C6E6"/>
        </Style>

        <!-- Menu Style -->
        <Style TargetType="Menu">
            <Setter Property="Background" Value="#3A1A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#9B4D96"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource WindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0">
            <MenuItem Header="_File">
                <MenuItem Header="_Clear Chat" Click="ClearChat_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Quiz">
                <MenuItem Header="_Start Quiz" Click="StartQuiz_Click"/>
                <MenuItem Header="_Cancel Quiz" Click="CancelQuiz_Click" x:Name="menuCancelQuiz" IsEnabled="False"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- Chat Display -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="10">
            <TextBox x:Name="txtChat" 
                     IsReadOnly="True" 
                     TextWrapping="Wrap"
                     FontFamily="Consolas"
                     FontSize="14"
                     BorderThickness="0"
                     Background="{x:Null}"
                     Foreground="#E6C6E6"
                     Margin="0,0,0,0"/>
        </ScrollViewer>

        <!-- Status / Quiz Progress -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10,5" Background="Transparent">
            <Label x:Name="lblQuizStatus" Content="Quiz: Not started" Foreground="#E6C6E6" FontWeight="Bold" FontSize="14"/>
            <Button x:Name="btnCancelQuiz" Content="Cancel Quiz" Style="{StaticResource PinkPurpleButton}" 
                    Visibility="Collapsed" Click="btnCancelQuiz_Click" Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Input Panel (with EXIT button) -->
        <Grid Grid.Row="3" Margin="10,0,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="txtUserInput" 
                     Grid.Column="0"
                     Height="35"
                     VerticalContentAlignment="Center"
                     KeyDown="txtUserInput_KeyDown"
                     ToolTip="Type your message and press Enter or click Send"/>
            <Button x:Name="btnSend" 
                    Grid.Column="1"
                    Content="Send" 
                    Style="{StaticResource PinkPurpleButton}"
                    Height="35"
                    Width="80"
                    Margin="10,0,0,0"
                    Click="btnSend_Click"
                    ToolTip="Send your message"/>
            <Button x:Name="btnAnswer" 
                    Grid.Column="2"
                    Content="Answer" 
                    Style="{StaticResource PinkPurpleButton}"
                    Height="35"
                    Width="80"
                    Margin="10,0,0,0"
                    Click="btnAnswer_Click"
                    ToolTip="Submit your quiz answer"/>
            <Button x:Name="btnExit" 
                    Grid.Column="3"
                    Content="EXIT" 
                    Style="{StaticResource RedExitButton}"
                    Height="35"
                    Width="80"
                    Margin="10,0,0,0"
                    Click="btnExit_Click"
                    ToolTip="Exit the application"/>
        </Grid>
    </Grid>
</Window>